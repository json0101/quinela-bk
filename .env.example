# Plantilla. Copia este archivo a .env y pon los valores reales.
# Comando:  cp .env.example .env

# --- Entorno de ejecucion de la API (.NET) ---
# En el SERVIDOR: Production (apaga Swagger). En LOCAL: Development.
ASPNET_ENV=Development

# --- Migraciones de Quinela (INTENCIONALES) ---
# Por defecto NO migra al arrancar. Pon true SOLO el arranque en que quieras migrar.
APPLY_MIGRATIONS=false

# --- Base de datos (Postgres) ---
# Superusuario: SOLO bootstrap/administracion. La API NO lo usa.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# --- Usuarios dedicados de la BD (menor privilegio) ---
# Generar 2 claves fuertes distintas:  openssl rand -base64 32
#   user_quinela -> RW sobre base 'quinela'
#   user_userapp -> RW sobre base 'userapp' (Quinela administra sec.* por migraciones)
QUINELA_DB_PASSWORD=
USERAPP_DB_PASSWORD=

# --- JWT: clave para firmar/validar los tokens de Quinela ---
# Generar con:  openssl rand -base64 48
QUINELA_JWT_SECRET=

# --- Licencia comercial de AutoMapper (la usa UserApp.Service) ---
# Reutiliza la misma de tu proyecto Tmis (.env -> USERAPP_AUTOMAPPER_LICENSE).
USERAPP_AUTOMAPPER_LICENSE=
